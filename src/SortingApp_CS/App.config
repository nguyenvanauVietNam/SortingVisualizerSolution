<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Người dùng có thể sửa các giá trị màu và ảnh nền tại đây rồi mở lại ứng dụng. -->
  <appSettings>
    <!-- Màu hỗ trợ tên màu .NET như Red hoặc mã HEX như #E53935. -->
    <add key="MovingColor" value="#E53935" />
    <add key="IdleColor" value="#1976D2" />
    <add key="CompletedColor" value="#43A047" />
    <!-- Đường dẫn có thể là tương đối theo thư mục chạy ứng dụng hoặc đường dẫn tuyệt đối. -->
    <add key="BackgroundImagePath" value="Resources\Backgrounds\default_bg.jpg" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
</configuration>
